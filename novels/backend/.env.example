# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# MiniMax API
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here

# Django Security (重要：生产环境必须设置)
DJANGO_SECRET_KEY=your-very-long-random-secret-key-here-change-in-production
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# CORS (生产环境配置)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-domain.com
CSRF_TRUSTED_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

# 文件上传限制
DATA_UPLOAD_MAX_MEMORY_SIZE=52428800
FILE_UPLOAD_MAX_MEMORY_SIZE=52428800

# MinIO Storage (可选，用于存储音频文件)
USE_MINIO=false
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_AUDIOBOOKS=audiobooks
MINIO_BUCKET_CHAPTERS=chapters
MINIO_BUCKET_SFX=sfx
MINIO_BUCKET_BGM=bgm
MINIO_BUCKET_UPLOADS=uploads
