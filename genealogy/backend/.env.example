# Development Environment
DEBUG=True
DJANGO_SECRET_KEY=dev-secret-key-change-in-production

# Database
DATABASE_URL=sqlite:///db.sqlite3

# Redis (optional for development)
REDIS_URL=redis://localhost:6379/0

# Hosts
ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000

# Frontend URL (for emails)
FRONTEND_URL=http://localhost:3000

# Email (console backend for development)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=dev@genealogy.local
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Stripe (optional for development)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# Sentry (optional)
SENTRY_DSN=

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# AI Configuration (OpenAI or Anthropic)
AI_PROVIDER=mock  # Options: openai, anthropic, mock
AI_API_KEY=       # Your OpenAI or Anthropic API key
OPENAI_API_KEY=   # OpenAI API key (alternative)
ANTHROPIC_API_KEY= # Anthropic API key (alternative)
OPENAI_API_BASE=https://api.openai.com/v1  # For proxy/custom endpoints
ANTHROPIC_API_BASE=https://api.anthropic.com

# OCR Configuration
OCR_PROVIDER=mock  # Options: mock, google_vision, openai_vision
GOOGLE_VISION_API_KEY=  # For Google Cloud Vision OCR
